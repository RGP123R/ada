#include<stdio.h>
#include<stdlib.h>

#define MAX 50

int can_place(int c[], int r) {
    int i; 
    for (i = 0; i < r; i++)
        if (c[i] == c[r] || abs(c[i] - c[r]) == abs(i - r)) 
            return 0;
    return 1;
}

void display(int c[], int n) {
    int i, j;
    char cb[MAX][MAX]; // Use MAX as defined earlier for flexibility
    
    // Initialize the board
    for (i = 0; i < n; i++) 
        for (j = 0; j < n; j++) 
            cb[i][j] = '-';
    
    // Place queens on the board
    for (i = 0; i < n; i++) 
        cb[i][c[i]] = 'Q';
    
    // Display the board
    for (i = 0; i < n; i++) {
        for (j = 0; j < n; j++) 
            printf("%c ", cb[i][j]);
        printf("\n");
    }
    printf("\n");
}

void n_queens(int n) {
    int r;
    int c[MAX]; // Array to store column positions of queens
    
    c[0] = -1; // Start with placing the queen in the first row at column -1
    r = 0; // Start with the first row
    
    while (r >= 0) {
        c[r]++; // Move to the next column in the current row
        while (c[r] < n && !can_place(c, r))
            c[r]++; // Move to the next column if conflict is found
        
        if (c[r] < n) {
            if (r == n - 1) {
                display(c, n); // If all queens are placed, display the board
                printf("\n\n");
            } else {
                r++; // Move to the next row
                c[r] = -1; // Start placing queen in the new row from column -1
            }
        } else {
            r--; // Backtrack to the previous row
        }
    }
}

int main() {
    int n;
    
    printf("\nEnter the number of queens:");
    scanf("%d", &n);
    
    n_queens(n); // Solve N-Queens problem for given n
    
    // Wait for user input before exiting
    printf("\nPress any key to exit...\n");
    getchar(); // Use getchar() to wait for user input
    
    return 0;
}
